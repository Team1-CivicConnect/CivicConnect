# ==========================================
# UBAYOG INCORPORATED: BACKEND NODE SECRETS
# ==========================================

# 1. CORE SERVER CONFIGURATION
PORT=5000
NODE_ENV=production
CLIENT_URL=https://civicconnect.ubayog.com

# 2. NOSQL DATABASE ARCHITECTURE
# Mapped to a secured Atlas Cloud Cluster
MONGODB_URI=mongodb+srv://<USER>:<PASSWORD>@ubayog-cluster.mongodb.net/civicconnect

# 3. CRYPTOGRAPHIC IDENTITY TOKENS
# Must be generated with exhaustive 256-bit cryptographically secure strings
JWT_SECRET=production_secret_key_1
JWT_REFRESH_SECRET=production_refresh_key_2

# 4. CLOUDINARY FILE STORAGE BUCKET
# Secure media ingestion hooks for civic evidence.
CLOUDINARY_CLOUD_NAME=your_production_cloud_name
CLOUDINARY_API_KEY=your_production_api_key
CLOUDINARY_API_SECRET=your_production_api_secret

# 5. ANTHROPIC AI PIPELINE ENGINE
# Requires Enterprise Tier 4 Access Key for 'DeepVerify' routing
ANTHROPIC_API_KEY=sk-ant-api03-...

# 6. EXTERNAL SMTP NOTIFICATIONS
# Outbound routing configuration for citizen alerts
EMAIL_USER=no-reply@ubayog.com
EMAIL_PASS=your_production_smtp_password
